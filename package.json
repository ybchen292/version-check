{
  "name": "version-check-js",
  "version": "1.1.0",
  "description": "version-check-js极简配置的前端版本检测工具，自动判断ETag/版本文件模式，默认自动轮询，保留手动检测 。原生javascript实现。不局限于框架使用",
  "main": "dist/index.js",
  "types": "index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "version-checker",
    "version-check",
    "version",
    "checker",
    "etag",
    "版本检测",
    "前端更新",
    "自动轮询"
  ],
  "author": "446354153@qq.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ybchen292/version-check"
  },
  "homepage": "https://github.com/ybchen292/version-check",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^3.0.0",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "20.16.0"
  }
}
